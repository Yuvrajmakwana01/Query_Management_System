        background: var(--text-main);
        color: white;
        padding: 60px 24px;
        border-radius: 32px;
        text-align: center;
        margin: 40px 24px 80px;
    }

    .btn-sp {
        background: var(--sp-primary);
        color: white;
        padding: 14px 32px;
        border-radius: 12px;
        font-weight: 700;
        text-decoration: none;
        display: inline-block;
        transition: 0.3s;
    }

    .btn-sp:hover { background: var(--sp-primary-hover); color: white; transform: translateY(-2px); }
</style>

