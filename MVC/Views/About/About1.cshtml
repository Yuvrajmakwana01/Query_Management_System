    }

    .section-label {
        color: var(--sp-primary);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.8rem;
        margin-bottom: 12px;
        display: block;
    }

    .section-title {
        font-weight: 800;
        font-size: 2.2rem;
        margin-bottom: 40px;
        letter-spacing: -0.01em;
    }

    /* --- STATS CARD --- */
    .intro-visual {
        background: white;
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .stat-box {
        text-align: center;
        padding: 20px;
        border-radius: 16px;
        background: #f1f5f9;
        transition: transform 0.3s;
    }

    .stat-box:hover { transform: translateY(-5px); }

    .stat-num {
        display: block;
        font-size: 2rem;
        font-weight: 800;
        color: var(--sp-primary);
    }

    /* --- FEATURE CARDS --- */
    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
    }

    .feature-card {
        background: white;
        padding: 32px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s;
    }

    .feature-card:hover {
        border-color: var(--sp-primary);
        box-shadow: 0 10px 30px -10px rgba(79, 70, 229, 0.2);
    }

    .feature-icon {
        font-size: 1.5rem;
        width: 50px;
        height: 50px;
        background: #eef2ff;
        color: var(--sp-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    /* --- TEAM CARDS --- */
    .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 24px;
    }

    .team-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        text-align: center;
        border: 1px solid #f1f5f9;
        transition: 0.3s;
    }

    .team-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
    }

    .team-card img {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 16px;
        border: 4px solid #f1f5f9;
    }

    .member-name { font-weight: 700; font-size: 1.1rem; margin-bottom: 4px; }
    .member-role { color: var(--text-muted); font-size: 0.85rem; font-weight: 500; }

    /* --- CTA --- */
