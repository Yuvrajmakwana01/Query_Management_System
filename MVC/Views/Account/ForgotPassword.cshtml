    .step-hdr p  { font-size: 14px; color: #6b7280; margin: 0 0 24px; line-height: 1.6; }

    .field-lbl {
        font-size: 12px; font-weight: 700; color: #374151;
        text-transform: uppercase; letter-spacing: .05em;
        display: block; margin-bottom: 6px;
    }
