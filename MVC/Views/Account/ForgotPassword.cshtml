    .sp-item.active .sp-circle { background: #4e73df; color: #fff; box-shadow: 0 0 0 4px #e8edff; }
    .sp-label { font-size: 11px; color: #aaa; margin-top: 5px; font-weight: 600; }
    .sp-item.active .sp-label { color: #4e73df; }

    .step-tag {
