    .btn-go {
        width: 100%;
        background: linear-gradient(135deg, #4e73df, #6f42c1);
        color: #fff; border: none;
        font-size: 15px; font-weight: 700;
        padding: 13px; border-radius: 10px; cursor: pointer;
        transition: opacity .15s, transform .12s;
        margin-top: 4px;
    }
    .btn-go:hover  { opacity: .9; transform: translateY(-1px); }
    .btn-go:disabled { opacity: .6; cursor: not-allowed; transform: none; }

    .alt-link { text-align: center; font-size: 13px; color: #9ca3af; margin-top: 18px; }
    .alt-link a { color: #4e73df; font-weight: 600; text-decoration: none; }
    .alt-link a:hover { text-decoration: underline; }

