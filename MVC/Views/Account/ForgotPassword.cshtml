</style>

<!-- Step progress -->

<div class="step-progress">
    <div class="sp-item active">
        <div class="sp-circle">1</div>
        <div class="sp-label">Email</div>
    </div>
    <div class="sp-item">
        <div class="sp-circle">2</div>
        <div class="sp-label">OTP</div>
    </div>
    <div class="sp-item">
        <div class="sp-circle">3</div>
        <div class="sp-label">Reset</div>
    </div>
</div>

<!-- Header -->

<div class="step-hdr">
    <div class="step-tag">Step 1 of 3</div>
    <h3>Forgot your password?</h3>
    <p id="emailHint">Enter your registered email to receive an OTP.</p>
</div>

<!-- Form -->

<div class="field-group">
    <label class="field-lbl">Registered Email <span style="color:#e74a3b">*</span></label>
    <input id="emailInput" type="email" />
</div>

<div id="alertBox" class="alert"></div>

<button id="btnSend" class="btn-go" type="button">Send OTP</button>

<div class="alt-link">
    Remembered your password? <a href="@Url.Action("Login", "Account")">Login here</a>
</div>


@section Scripts {

<script>
$(document).ready(function () {

    // ✅ Fixed placeholder
    $("#emailInput").kendoTextBox({ placeholder: "example@company.com" });

    $("#btnSend").click(function () {
        var email = $("#emailInput").val().trim();

        if (!email) {
            Swal.fire({
                icon: 'warning',
                title: 'Email Required',
                text: 'Please enter your email address.',
                confirmButtonColor: '#4e73df'
            });
            return;
        }

      

        $("#btnSend").prop("disabled", true).text("Sending...");

        // Loading popup
        Swal.fire({
            title: 'Sending OTP...',
            text: 'Please wait while we send the OTP.',
            allowOutsideClick: false,
            allowEscapeKey: false,
            didOpen: () => { Swal.showLoading(); }
        });

        $.ajax({
            url: '@Url.Action("ForgotPassword","Account")',
            type: 'POST',
            data: { email: email },

            success: function (res) {
                Swal.close(); // ✅ FIX

                if (res.success) {
                    sessionStorage.setItem("resetEmail", email);

                    Swal.fire({
                        icon: 'success',
                        title: 'OTP Sent!',
                        text: res.message,
                        confirmButtonColor: '#1cc88a'
                    }).then(function () {
                        window.location.href = '@Url.Action("VerifyOtp","Account")';
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Failed!',
                        text: res.message,
                        confirmButtonColor: '#e74a3b'
                    });

                    $("#btnSend").prop("disabled", false).text("Send OTP"); // ✅ FIX
                }
            },

            error: function () {
                Swal.close(); // ✅ FIX

                Swal.fire({
                    icon: 'error',
                    title: 'Server Error',
                    text: 'Something went wrong. Please try again.',
                    confirmButtonColor: '#e74a3b'
                });

                $("#btnSend").prop("disabled", false).text("Send OTP"); // ✅ FIX
            }
        });
    });

    // Enter key support
    $(document).keypress(function (e) {
        if (e.which == 13) $("#btnSend").click();
    });

});
</script>

} *@


@{
    Layout = "../Shared/_ForgotPasswordLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --accent-color: #764ba2;
        --soft-bg: #f8f9fa;
    }

    /* Premium Step Progress */
    .step-progress {
        display: flex;
        align-items: center;
        margin-bottom: 40px;
        padding: 0 10px;
    }
    .sp-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        position: relative;
    }
    .sp-item:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 15px;
        left: 60%;
        right: -40%;
        height: 3px;
        background: #eee;
        z-index: 0;
        border-radius: 2px;
    }
    .sp-item.active:not(:last-child)::after {
        background: var(--primary-gradient);
    }
    .sp-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 800;
        background: #fff;
        color: #ced4da;
        border: 2px solid #eee;
        position: relative;
        z-index: 1;
        transition: all 0.3s ease;
    }
    .sp-item.active .sp-circle {
        background: var(--primary-gradient);
        color: #fff;
        border-color: transparent;
        box-shadow: 0 4px 10px rgba(118, 75, 162, 0.3);
    }
    .sp-label {
        font-size: 11px;
        color: #adb5bd;
        margin-top: 8px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .sp-item.active .sp-label {
        color: var(--accent-color);
    }

    /* Header & Typography */
    .step-tag {
        display: inline-block;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #fff;
        background: var(--primary-gradient);
        padding: 4px 14px;
        border-radius: 50px;
        margin-bottom: 15px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .step-hdr h3 {
        font-size: 28px;
        font-weight: 800;
        color: #2d3436;
        margin-bottom: 10px;
        letter-spacing: -0.5px;
    }
    .step-hdr p {
        font-size: 15px;
        color: #636e72;
        margin-bottom: 30px;
        line-height: 1.5;
    }

    /* Form Styling */
    .field-lbl {
        font-size: 12px;
        font-weight: 700;
        color: #495057;
        margin-bottom: 8px;
        display: block;
    }
    .field-group { margin-bottom: 25px; }

    /* Kendo Input Customization */
    .k-textbox {
        width: 100% !important;
        padding: 12px !important;
        border-radius: 8px !important;
    }

    /* Action Button */
    .btn-go {
        width: 100%;
        background: var(--primary-gradient);
        color: #fff;
        border: none;
        font-size: 16px;
        font-weight: 700;
        padding: 15px;
        border-radius: 10px;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.25);
        transition: all 0.3s ease;
    }
    .btn-go:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.35);
        opacity: 0.95;
    }
    .btn-go:active { transform: translateY(0); }

    .alt-link {
        text-align: center;
        font-size: 14px;
        color: #636e72;
        margin-top: 25px;
    }
    .alt-link a {
        color: var(--accent-color);
        font-weight: 700;
        text-decoration: none;
        border-bottom: 2px solid transparent;
        transition: all 0.2s;
    }
    .alt-link a:hover {
        border-bottom-color: var(--accent-color);
    }
</style>

<div class="step-progress">
    <div class="sp-item active">
        <div class="sp-circle">1</div>
        <div class="sp-label">Identify</div>
    </div>
    <div class="sp-item">
        <div class="sp-circle">2</div>
        <div class="sp-label">Verify</div>
    </div>
    <div class="sp-item">
        <div class="sp-circle">3</div>
        <div class="sp-label">Secure</div>
    </div>
</div>

<div class="step-hdr">
    <div class="step-tag">Phase 01</div>
    <h3>Reset Password</h3>
    <p id="emailHint">Enter your registered email address. We'll send a secure OTP to verify your identity.</p>
</div>

<div class="field-group">
    <label class="field-lbl">Business Email <span class="text-danger">*</span></label>
    <input id="emailInput" type="email" style="width: 100%;" />
</div>

<button id="btnSend" class="btn-go" type="button">Request OTP</button>

<div class="alt-link">
    Suddenly remembered? <a href="@Url.Action("Login", "Account")">Sign In</a>
</div>

@section Scripts {
<script>
$(document).ready(function () {
    // Initialize Kendo TextBox with premium look
    $("#emailInput").kendoTextBox({
        placeholder: "e.g. brijesh@solvepoint.com",
        fillMode: "flat" // Matches modern minimalist UI
    });

    $("#btnSend").click(function () {
        var email = $("#emailInput").val().trim();

        if (!email) {
            Swal.fire({
                icon: 'warning',
                title: 'Required',
                text: 'Please enter your email to proceed.',
                confirmButtonColor: '#764ba2'
            });
            return;
        }

        $("#btnSend").prop("disabled", true).html('<span class="k-icon k-i-loading"></span> Sending...');

        Swal.fire({
            title: 'Verifying Identity...',
            text: 'Securing connection and sending OTP.',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        $.ajax({
            url: '@Url.Action("ForgotPassword","Account")',
            type: 'POST',
            data: { email: email },
            success: function (res) {
                Swal.close();
                if (res.success) {
                    sessionStorage.setItem("resetEmail", email);
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: res.message,
                        confirmButtonColor: '#28a745'
                    }).then(() => {
                        window.location.href = '@Url.Action("VerifyOtp","Account")';
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: res.message,
                        confirmButtonColor: '#764ba2'
                    });
                    $("#btnSend").prop("disabled", false).text("Request OTP");
                }
            },
            error: function () {
                Swal.close();
                Swal.fire({
                    icon: 'error',
                    title: 'System Error',
                    text: 'Unable to reach the server. Please try again later.',
                    confirmButtonColor: '#764ba2'
                });
                $("#btnSend").prop("disabled", false).text("Request OTP");
            }
        });
    });

    $(document).keypress(function (e) {
        if (e.which == 13) $("#btnSend").click();
    });
});
</script>
}