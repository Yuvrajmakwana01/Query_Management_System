    <script>
    $(document).ready(function () {
        $("#email").kendoTextBox({
            placeholder: "Enter your email...",
            label: "Email"
        });

        $("#password").kendoTextBox({
            placeholder: "Enter password...",
            label: "Password"
        });

        var validator = $("#loginForm").kendoValidator().data("kendoValidator");

        $("#btnLogin").click(function () {
            if (validator.validate()) {
                var loginData = {
                    email: $("#email").val(),
                    password: $("#password").val()
                };

                // Premium Loading State
                Swal.fire({
                    title: 'Authenticating...',
                    html: 'Please wait while we verify your credentials.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '@Url.Action("Login", "Account")',
                    type: 'POST',
                    data: loginData,
                    success: function (response) {
                        if (response.success) {
                            // Success Toast
                            Swal.fire({
                                icon: 'success',
                                title: 'Access Granted',
                                text: 'Welcome to SolvePoint!',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(function () {
                                if (response.role === "Admin") {
                                    window.location.href = '@Url.Action("Index", "Admin")';
                                } else if (response.role === "Employee") {
                                    window.location.href = '@Url.Action("Dashboard", "Employee")';
                                } else {
                                    window.location.href = '@Url.Action("Dashboard", "Query")';
                                }
                            });
                        } else {
                            // Login Failed
                            Swal.fire({
                                icon: 'error',
                                title: 'Login Failed',
                                text: response.message,
                                confirmButtonColor: '#2563eb'
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'System Error',
                            text: 'Something went wrong on our end. Please try again.',
                            confirmButtonColor: '#2563eb'
                        });
                    }
                });
            }
        });

        $(document).keypress(function (e) {
            if (e.which == 13) {
                $("#btnLogin").click();
            }
        });
    });
</script>

</body>

</html>