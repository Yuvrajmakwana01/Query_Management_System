@{
Layout = "../Shared/_ForgotPasswordLayout.cshtml";
ViewData["Title"] = "Reset Password";
}

<style>
    .step-progress {
        display: flex; align-items: center; margin-bottom: 32px;
    }
    .sp-item {
        display: flex; flex-direction: column; align-items: center;
        flex: 1; position: relative;
    }
    .sp-item:not(:last-child)::after {
        content: ''; position: absolute;
        top: 14px; left: 55%; right: -50%;
        height: 2px; background: #1cc88a; z-index: 0;
    }
    .sp-circle {
        width: 28px; height: 28px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700;
        position: relative; z-index: 1;
    }
    .sp-item.done   .sp-circle { background: #1cc88a; color: #fff; }
    .sp-item.active .sp-circle { background: #4e73df; color: #fff; box-shadow: 0 0 0 4px #e8edff; }
    .sp-label { font-size: 11px; color: #aaa; margin-top: 5px; font-weight: 600; }
    .sp-item.done   .sp-label { color: #1cc88a; }
    .sp-item.active .sp-label { color: #4e73df; }

    .step-tag {
        display: inline-block; font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: .07em;
        color: #1cc88a; background: #d4f5e9;
        padding: 4px 12px; border-radius: 20px; margin-bottom: 12px;
    }
    .step-hdr h3 { font-size: 24px; font-weight: 800; color: #1a1a2e; margin: 0 0 8px; }
    .step-hdr p  { font-size: 14px; color: #6b7280; margin: 0 0 24px; }

    .field-lbl {
        font-size: 12px; font-weight: 700; color: #374151;
        text-transform: uppercase;
        display: block; margin-bottom: 6px;
    }
    .field-group { margin-bottom: 16px; }

    .strength-wrap { margin: -4px 0 16px; }
    .strength-bar  { height: 5px; background: #e5e7eb; border-radius: 3px; margin-bottom: 5px; }
    .strength-fill { height: 100%; border-radius: 3px; width: 0; transition: .3s; }
    .strength-lbl  { font-size: 12px; font-weight: 600; color: #9ca3af; }

    .req-list { display: flex; flex-direction: column; gap: 4px; margin-bottom: 18px; }
    .req-item { font-size: 12px; color: #bbb; }
    .req-item.met { color: #1cc88a; }
    .req-item.met::before { content: "✅ "; }
    .req-item:not(.met)::before { content: "○ "; }

    #matchMsg { font-size: 12px; margin-bottom: 14px; }

    .btn-go {
        width: 100%;
        background: linear-gradient(135deg, #1cc88a, #16a673);
        color: #fff; border: none;
        font-size: 15px; font-weight: 700;
        padding: 13px; border-radius: 10px; cursor: pointer;
    }
</style>

<!-- Progress -->

<div class="step-progress">
    <div class="sp-item done">
        <div class="sp-circle">✓</div>
        <div class="sp-label">Email</div>
    </div>
    <div class="sp-item done">
        <div class="sp-circle">✓</div>
        <div class="sp-label">OTP</div>
    </div>
    <div class="sp-item active">
        <div class="sp-circle">3</div>
        <div class="sp-label">Reset</div>
    </div>
</div>

<div class="step-hdr">
    <div class="step-tag">Final Step</div>
    <h3>Set New Password</h3>
    <p>Choose a strong password (min 6 characters).</p>
</div>

<!-- Password -->

<div class="field-group">
    <label class="field-lbl">New Password *</label>
    <input id="newPass" type="password" />
</div>

<div class="strength-wrap">
    <div class="strength-bar"><div id="sFill" class="strength-fill"></div></div>
    <span id="sLbl" class="strength-lbl">Password strength</span>
</div>

<div class="req-list">
    <div id="req-len" class="req-item">At least 6 characters</div>
    <div id="req-upper" class="req-item">One capital letter</div>
    <div id="req-num" class="req-item">One number</div>
</div>

<!-- Confirm -->

<div class="field-group">
    <label class="field-lbl">Confirm Password *</label>
    <input id="confPass" type="password" />
</div>

<div id="matchMsg"></div>

<button id="btnReset" class="btn-go">Reset Password</button>

@section Scripts {

<script>
$(document).ready(function () {

    $("#newPass").kendoTextBox({ placeholder: "New password..." });
    $("#confPass").kendoTextBox({ placeholder: "Confirm password..." });

    // Strength
    $("#newPass").on("input", function () {
        var p = $(this).val();
        var l = p.length >= 6, u = /[A-Z]/.test(p), n = /[0-9]/.test(p);
        var score = [l, u, n].filter(Boolean).length;

        $("#req-len").toggleClass("met", l);
        $("#req-upper").toggleClass("met", u);
        $("#req-num").toggleClass("met", n);

        var colors = ["#e74a3b","#f6c23e","#1cc88a"];
        var labels = ["Weak","Medium","Strong"];
        var widths = ["33%","66%","100%"];

        if (!p) {
            $("#sFill").css({ width: 0 });
            $("#sLbl").text("Password strength");
        } else {
            $("#sFill").css({ width: widths[score-1], background: colors[score-1] });
            $("#sLbl").text(labels[score-1]);
        }
    });

    // Match
    $("#confPass").on("input", function () {
        var p1 = $("#newPass").val();
        var p2 = $(this).val();

        $("#matchMsg").html(p1 === p2
            ? "<span style='color:green'>Passwords match</span>"
            : "<span style='color:red'>Passwords do not match</span>");
    });

    // Submit
    $("#btnReset").click(function () {
        var np = $("#newPass").val();
        var cp = $("#confPass").val();

        if (!np || !cp) {
            Swal.fire("Fill all fields");
            return;
        }

        if (np !== cp) {
            Swal.fire("Passwords do not match");
            return;
        }

        $("#btnReset").prop("disabled", true).text("Resetting...");

        Swal.fire({
            title: "Resetting...",
            didOpen: () => Swal.showLoading()
        });

        $.ajax({
            url: '@Url.Action("ResetPassword","Account")',
            type: 'POST',
            data: { newPassword: np, confirmPassword: cp },

            success: function (res) {
                Swal.close(); // ✅ FIX

                if (res.success) {
                    Swal.fire("Success").then(() => {
                        window.location.href = '@Url.Action("Login","Account")';
                    });
                } else {
                    Swal.fire(res.message);
                    $("#btnReset").prop("disabled", false).text("Reset Password");
                }
            },

            error: function () {
                Swal.close(); // ✅ FIX
                Swal.fire("Server error");
                $("#btnReset").prop("disabled", false).text("Reset Password");
            }
        });
    });

    // Enter key support
    $(document).keypress(function (e) {
        if (e.which == 13) $("#btnReset").click();
    });

});
</script>

}