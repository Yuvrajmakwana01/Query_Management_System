@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Reusable Premium Toast
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: '#ffffff',
                color: '#0f172a'
            });

            $("#grid").kendoGrid({
                dataSource: {
                    transport: {
                        read: {
                            url: '@Url.Action("GetAllUsersData", "Admin")',
                            type: "GET",
                            dataType: "json"
                        }
                    },
                    schema: {
                        model: {
                            id: "c_UserId",
                            fields: {
                                c_UserId: { type: "number" },
                                c_UserName: { type: "string" },
                                c_CompanyName: { type: "string" },
                                c_EmailId: { type: "string" }
                            }
                        }
                    },
                    pageSize: 10
                },
                toolbar: ["search"],
                pageable: { refresh: true, pageSizes: [10, 20, 50], buttonCount: 5 },
                sortable: true,
                filterable: true,
                height: 700,
                noRecords: {
                    template: "<div class='p-5 text-center text-muted'>No active user records found in the directory.</div>"
                },
                columns: [
                    {
                        field: "c_UserId",
                        title: "System ID",
                        width: 100,
                        attributes: { style: "text-align: center;" },
                        template: "<span class='id-badge'>\\# #: c_UserId #</span>"
                    },
                    {
                        field: "c_UserName",
                        title: "Full Name",
                        width: 220,
                        template: "<div class='user-name'>#: c_UserName #</div>"
                    },
                    {
                        field: "c_CompanyName",
                        title: "Organization",
                        width: 200,
                        template: "<span class='company-tag'>#: c_CompanyName #</span>"
                    },
                    {
                        field: "c_EmailId",
                        title: "Communication",
                        template: "<a class='email-link' href='mailto:\\#:c_EmailId\\#'><i class='k-icon k-i-email'></i> #:c_EmailId#</a>"
                    },
                    {
                        title: "Actions",
                        width: 100,
                        attributes: { style: "text-align: center;" },
                        template: `<button class='k-button btn-action-delete' title='Delete User' onclick='deleteUser(#=c_UserId#, "#:c_UserName#")'>
                                    <span class='k-icon k-i-trash'></span>
                                   </button>`
                    }
                ]
            });

            // Global delete function
            window.deleteUser = function(id, name) {
                Swal.fire({
                    title: 'Remove User?',
                    text: `Are you sure you want to delete ${name}? This action is permanent.`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444', // Matches your .btn-action-delete hover
                    cancelButtonColor: '#94a3b8',
                    confirmButtonText: 'Yes, Delete',
                    cancelButtonText: 'Cancel',
                    background: '#ffffff',
                    borderRadius: '20px',
                    customClass: {
                        title: 'fw-bold',
                        popup: 'shadow-lg'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Show non-blocking loading state
                        Swal.fire({
                            title: 'Processing...',
                            didOpen: () => { Swal.showLoading(); },
                            allowOutsideClick: false,
                            showConfirmButton: false
                        });

                        $.ajax({
                            url: '/Admin/DeleteUser/' + id,
                            type: 'POST',
                            success: function (res) {
                                Swal.close(); // Close loading
                                if (res.success !== false) {
                                    Toast.fire({
                                        icon: 'success',
                                        title: 'User record deleted'
                                    });
                                    refreshGrid();
                                } else {
                                    Swal.fire('Error', res.message || 'Deletion failed.', 'error');
                                }
                            },
                            error: function () {
                                Swal.close();
                                Swal.fire('System Error', 'Unable to reach the server.', 'error');
                            }
                        });
                    }
                });
            };
        });

        function refreshGrid() {
            var grid = $("#grid").data("kendoGrid");
            if (grid) grid.dataSource.read();
        }
    </script>
}