@{
    Layout = "../Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --sp-brand: #0f172a;
        /* Midnight Slate */
        --sp-accent: #2563eb;
        /* Royal Blue */
        --sp-border: #e2e8f0;
        --sp-bg-subtle: #f8fafc;
        --sp-success: #10b981;
    }

    body {
        background-color: #f1f5f9;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    /* Glass-Effect Header */
    .view-header {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        padding: 32px;
        border-radius: 24px;
        border: 1px solid var(--sp-border);
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .header-info h2 {
        font-weight: 800;
        color: var(--sp-brand);
        font-size: 1.75rem;
        letter-spacing: -0.025em;
        margin: 0;
    }

    .header-info p {
        color: #64748b;
        margin: 4px 0 0 0;
        font-size: 0.95rem;
    }

    /* Grid Wrapper */
    .grid-wrapper {
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid var(--sp-border);
        padding: 10px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
    }

    /* Kendo Customization for Professional Look */
    .k-grid {
        border: none !important;
        font-size: 14px;
    }

    .k-grid-header {
        background: transparent !important;
        border-bottom: 2px solid #f1f5f9 !important;
    }

    .k-grid-header th.k-header {
        padding: 16px 20px !important;
        background: none !important;
        border: none !important;
    }

    .k-grid-header .k-link {
        color: #94a3b8 !important;
        font-weight: 700 !important;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 11px;
    }

    .k-grid td {
        padding: 20px !important;
        border-bottom: 1px solid #f8fafc !important;
        color: #334155;
    }

    .k-master-row:hover {
        background-color: #f8fafc !important;
    }

    /* Custom Cell Styling */
    .id-badge {
        font-family: 'JetBrains Mono', monospace;
        color: #94a3b8;
        font-weight: 500;
        font-size: 12px;
    }

    .user-name {
        color: var(--sp-brand);
        font-weight: 700;
        font-size: 15px;
    }

    .company-tag {
        background: #eff6ff;
        color: #1e40af;
        padding: 4px 12px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid #dbeafe;
    }

    .email-link {
        color: var(--sp-accent);
        text-decoration: none;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    /* Specialized Delete Button */
    .btn-action-delete {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #fff !important;
        color: #ef4444 !important;
        border: 1px solid #fee2e2 !important;
        border-radius: 10px !important;
        transition: all 0.2s ease;
    }

    .btn-action-delete:hover {
        background: #ef4444 !important;
        color: #fff !important;
        box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.2);
    }

    /* Toolbar Search Bar */
    .k-grid-toolbar {
        background: transparent !important;
        border-bottom: 1px solid #f1f5f9 !important;
        padding: 15px !important;
    }

    .k-searchbar {
        border-radius: 10px !important;
        width: 300px !important;
    }
</style>

<div class="container-fluid py-5 px-5">
    <div class="view-header">
        <div class="header-info d-flex align-items-center">
            <div class="header-icon-box">
                <i class="k-icon k-i-user me-3" style="font-size: 45px; color: rgb(132, 196, 204);"></i>
            </div>
            <div>
            <h2>User Management</h2>
            <p>Admin Control Panel &bull; System Directory</p>
            </div>
        </div>
        <div>
            @* <button class="k-button k-button-md k-rounded-md k-button-solid-primary" onclick="refreshGrid()">
                <span class="k-icon k-i-reload"></span> Sync Data
            </button> *@
        </div>
    </div>

    <div class="grid-wrapper">
        <div id="grid"></div>
    </div>
</div>
