@{
    ViewData["Title"] = "Help & Support";
    Layout = "_Layout";
}

<style>
    .help-hero {
        background: linear-gradient(135deg, #a33cf1 0%, #6c66e1 100%);
        padding: 60px 0;
        border-radius: 20px;
        color: white;
        margin-bottom: 40px;
    }
    .search-container {
        max-width: 600px;
        margin: 0 auto;
        position: relative;
    }
    .search-container .form-control {
        height: 55px;
        border-radius: 30px;
        padding-left: 50px;
        border: none;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }
    .search-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
    }
    .feature-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        cursor: pointer;
    }
    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }
    .accordion-item {
        border: none;
        margin-bottom: 10px;
        border-radius: 12px !important;
        overflow: hidden;
        background: #f8fafc;
    }
    .accordion-button {
        background: #f8fafc;
        font-weight: 600;
        color: #1e293b;
    }
    .accordion-button:not(.collapsed) {
        background: #eef2ff;
        color: #4f46e5;
        box-shadow: none;
    }
    .status-badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
    }
</style>

<div class="container mt-4">
    
    <div class="help-hero text-center shadow-sm">
        <h1 class="fw-bold">How can we help?</h1>
        <p class="opacity-75 mb-4">Search our knowledge base or browse frequently asked questions</p>
        
        <div class="search-container">
            <i class="bi bi-search search-icon fs-5"></i>
            <input type="text" id="helpSearch" class="form-control" placeholder="Type your question here...">
        </div>
    </div>

    <div class="row g-4 mb-5 text-center">
        <div class="col-md-4">
            <a href="/Query/Dashboard" class="text-decoration-none text-dark">
                <div class="card feature-card shadow-sm  h-100 p-4">
                    <div class="mb-3"><i class="bi bi-speedometer2 fs-1 text-primary"></i></div>
                    <h5>My Dashboard</h5>
                    <p class="text-muted small">Manage your current queries and track progress.</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/Query/QueryDashboard" class="text-decoration-none text-dark">
                <div class="card feature-card shadow-sm  h-100 p-4">
                    <div class="mb-3"><i class="bi bi-plus-circle fs-1 text-success"></i></div>
                    <h5>New Query</h5>
                    <p class="text-muted small">Submit a new support ticket to our team.</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <div class="card feature-card shadow-sm h-100 p-4" onclick="location.href='mailto:solvepoint001@gmail.com'">
                <div class="mb-3"><i class="bi bi-envelope fs-1 text-danger"></i></div>
                <h5>Direct Support</h5>
                <p class="text-muted small">Contact us via email for complex issues.</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <h4 class="mb-4 fw-bold">Common Questions</h4>
            <div class="accordion" id="faqAccordion">

                <div class="accordion-item shadow-sm">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#q1">
                            How do I create a new query?
                        </button>
                    </h2>
                    <div id="q1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            To create a query, navigate to your <a href="/Query/QueryDashboard">Query Dashboard</a>, click the <strong>"Create Query"</strong> button, fill in your title and description, and click submit. Our system will immediately index it and notify an administrator.
                        </div>
                    </div>
                </div>

                <div class="accordion-item shadow-sm">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q3">
                            Understanding Query Statuses
                        </button>
                    </h2>
                    <div id="q3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            <div class="d-flex flex-column gap-2">
                                <div><span class="status-badge bg-success text-white">Resolved</span> The issue has been fixed by an employee.</div>
                                <div><span class="status-badge bg-warning text-dark">In Progress</span> An employee is currently working on it.</div>
                                <div><span class="status-badge bg-secondary text-white">Pending</span> The query is in the queue and waiting for assignment.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="accordion-item shadow-sm">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q2">
                            Tracking and Managing Queries
                        </button>
                    </h2>
                    <div id="q2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            Your main <a href="/Query/Dashboard">Dashboard</a> lists all your tickets. You can use the search bar at the top of the grid to find specific queries by ID or keyword. If you wish to delete a query, click the trash icon next to the record.
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 bg-light" style="border-radius: 16px;">
                <h5 class="fw-bold mb-3">Support Details</h5>
                <ul class="list-unstyled mb-4">
                    <li class="mb-3 d-flex align-items-center">
                        <i class="bi bi-clock me-3 text-primary fs-5"></i>
                        <span>Response Time: <strong>24 Hours</strong></span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="bi bi-envelope-at me-3 text-primary fs-5"></i>
                        <span>solvepoint001@gmail.com</span>
                    </li>
                    <li class="d-flex align-items-center">
                        <i class="bi bi-geo-alt me-3 text-primary fs-5"></i>
                        <span>Remote Support Center</span>
                    </li>
                </ul>
                <div class="alert alert-info border-0 small mb-0">
                    <strong>Note:</strong> Our system uses ElasticSearch for lightning-fast query retrieval.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
            $("#helpSearch").on("keyup", function () {
                var value = $(this).val().toLowerCase();

                // Search through accordion items
                $(".accordion-item").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });

                // Open the first visible accordion item if searching
                if(value.length > 0) {
                    $(".accordion-collapse:visible").first().addClass("show");
                }
            });
        });
    </script>
}