    <script src="~/lib/kendo/kendo.all.min.js"></script>

    <script>

        document.addEventListener("DOMContentLoaded", function () {
            const preloader = document.getElementById('preloader');

            window.addEventListener('load', function () {
                // Give it a tiny extra moment for Kendo UI to settle
                setTimeout(() => {
                    preloader.classList.add('preloader-hidden');
                }, 800);
            });
        });

        // Toggle Logic
        function toggleNotifications(event) {
            event.stopPropagation();
            const box = $("#notifBox");
            const isVisible = box.is(":visible");

            if (!isVisible) {
                box.fadeIn(150);
                loadNotificationList();
            } else {
                box.fadeOut(100);
            }
        }

        // Close when clicking anywhere else
        $(document).on("click", function (e) {
            if (!$(e.target).closest('.user-notif-wrapper').length) {
                $("#notifBox").fadeOut(100);
            }
        });

        function loadNotifications() {
            $.get('/Query/GetNotificationCount', function (data) {
                let count = parseInt(data) || 0;
                if (count > 0) {
                    $("#notifCount").text(count).show();
                } else {
                    $("#notifCount").hide();
                }
            });
        }

        function loadNotificationList() {
            $("#notifList").html('<li class="user-notif-empty">Loading...</li>');
            $.get('/Query/GetNotifications', function (data) {
                let html = "";
                if (!data || data.length === 0) {
                    html = "<li class='user-notif-empty'>No new updates</li>";
                } else {
                    data.reverse().forEach(function (item) {
                        html += `
                            <li class="user-notif-item">
                                <i class="bi bi-info-circle-fill text-primary" style="font-size: 1rem;"></i>
                                <span>${item}</span>
                            </li>`;
                    });
                }
                $("#notifList").html(html);
            });
        }

        function clearNotifications() {
            $.post('/Query/ClearNotifications', function () {
                $("#notifList").html("<li class='user-notif-empty'>No new updates</li>");
                $("#notifCount").hide();
            });
        }

        // Polling every 10 seconds
        setInterval(loadNotifications, 10000);
        loadNotifications();



    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

