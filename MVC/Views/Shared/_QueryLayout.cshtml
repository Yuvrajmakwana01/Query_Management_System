            width: 100%;
            border: none;
            border-radius: 12px;
            padding: 11px 14px;
            font-size: 13px;
            font-weight: 700;
            color: #fff;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow: 0 12px 24px rgba(37, 99, 235, 0.25);
        }

        .user-notif-btn:hover {
            background: linear-gradient(135deg, #1d4ed8, #1e40af);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area=""><i class="bi bi-journal-check text-success"></i>&nbsp; SolvePoint</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        /* <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li> */
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Query" asp-action="QueryDashboard">Query</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Query" asp-action="Logout">Logout</a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="user-notif-trigger" onclick="toggleNotifications()">
                <i class="k-icon k-i-bell" style="font-size:25px;"></i>

                <span id="notifCount" class="user-notif-count">
                </span>
            </div>

            <div id="notifBox" class="user-notif-box">
                <div class="user-notif-header">
                    <p class="user-notif-title">Notifications</p>
                    <p class="user-notif-subtitle">Stay updated when your query gets resolved.</p>
                </div>

                <ul id="notifList" class="user-notif-list"></ul>

                <div class="user-notif-footer">
                    <button onclick="clearNotifications()" class="user-notif-btn">
                        Mark as Read
                    </button>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>
    <script>
        let isOpen = false;

        function loadNotifications() {
            $.get('/Query/GetNotificationCount', function (data) {
                $("#notifCount").text(data);
            });
        }

        function loadNotificationList() {
            $.get('/Query/GetNotifications', function (data) {
                let html = "";

                if (data.length === 0) {
                    html = "<li class='user-notif-empty'>No notifications yet</li>";
                } else {
                    data.reverse().forEach(function (item) {
                        html += `<li class="user-notif-item">${item}</li>`;
                    });
                }

                $("#notifList").html(html);
            });
        }

        function toggleNotifications() {
            isOpen = !isOpen;

            if (isOpen) {
                $("#notifBox").show();
                loadNotificationList();
            } else {
                $("#notifBox").hide();
            }
        }

        function clearNotifications() {
            $.post('/Query/ClearNotifications', function () {
                $("#notifList").html("<li class='user-notif-empty'>No notifications yet</li>");
                $("#notifCount").text("0");
            });
        }

        setInterval(loadNotifications, 3000);
        loadNotifications();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> *@


@* 
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SolvePoint</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --sp-primary: #2563eb;
            --sp-bg: #f8fafc;
            --nav-height: 70px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--sp-bg);
            padding-top: var(--nav-height);
        }

        /* --- MODERN NAVBAR --- */
        .navbar-custom {
            height: var(--nav-height);
            background: rgba(255, 255, 255, 0.8) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid #e2e8f0;
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.25rem;
            letter-spacing: -0.02em;
        }

        .nav-link {
            font-weight: 600;
            color: #475569 !important;
            padding: 0.5rem 1rem !important;
            transition: color 0.2s;
        }

        .nav-link:hover { color: var(--sp-primary) !important; }

        /* --- NOTIFICATION TRIGGER RE-STYLING --- */
        .user-notif-wrapper { position: relative; }

        .user-notif-trigger {
            position: relative;
            cursor: pointer;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            border: 1px solid #e2e8f0;
            color: #64748b;
            transition: all 0.2s ease;
        }

        .user-notif-trigger:hover {
            background: #e2e8f0;
            color: var(--sp-primary);
        }

        /* --- UPDATED NOTIFICATION BOX --- */
        .user-notif-box {
            display: none;
            position: absolute;
            right: 0;
            top: 55px;
            width: 320px;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border: 1px solid #e2e8f0;
            z-index: 1050;
            overflow: hidden;
            animation: fadeInScale 0.2s ease-out;
        }

        @@keyframes fadeInScale {
            from { opacity: 0; transform: scale(0.95) translateY(-10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* --- SCROLLBAR STYLING --- */
        .user-notif-list::-webkit-scrollbar { width: 5px; }
        .user-notif-list::-webkit-scrollbar-track { background: #f1f5f9; }
        .user-notif-list::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        /* --- FOOTER --- */
        .footer-custom {
            background: #fff;
            padding: 2rem 0;
            border-top: 1px solid #e2e8f0;
            margin-top: 4rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light fixed-top navbar-custom">
            <div class="container">
                <a class="navbar-brand text-primary" asp-controller="Query" asp-action="QueryDashboard">
                    <i class="bi bi-intersect me-2"></i>SolvePoint
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navContent">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Query" asp-action="QueryDashboard">Dashboard</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <div class="user-notif-wrapper">
                            <div class="user-notif-trigger" onclick="toggleNotifications()">
                                <i class="bi bi-bell-fill"></i>
                                <span id="notifCount" class="user-notif-count">0</span>
                            </div>

                            <div id="notifBox" class="user-notif-box">
                                <div class="user-notif-header">
                                    <p class="user-notif-title">Notifications</p>
                                    <p class="user-notif-subtitle">Updates on your active queries.</p>
                                </div>
                                <ul id="notifList" class="user-notif-list"></ul>
                                <div class="user-notif-footer">
                                    <button onclick="clearNotifications()" class="user-notif-btn">
                                        Mark all as read
                                    </button>
                                </div>
                            </div>
                        </div>

                        <a class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold" asp-controller="Query" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">
        <div class="container text-center">
            <span class="text-muted small">&copy; 2026 SolvePoint QMS. All rights reserved.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        let isOpen = false;

        // Auto-close notification box when clicking outside
        $(document).click(function(e) {
            if (!$(e.target).closest('.user-notif-wrapper').length) {
                $("#notifBox").hide();
                isOpen = false;
            }
        });

        function loadNotifications() {
            $.get('/Query/GetNotificationCount', function (data) {
                let count = parseInt(data) || 0;
                $("#notifCount").text(count);
                // Hide badge if count is 0
                count > 0 ? $("#notifCount").show() : $("#notifCount").hide();
            });
        }

        function loadNotificationList() {
            $.get('/Query/GetNotifications', function (data) {
                let html = "";
                if (!data || data.length === 0) {
                    html = "<li class='user-notif-empty'>No new updates</li>";
                } else {
                    data.reverse().forEach(function (item) {
                        html += `<li class="user-notif-item"><i class="bi bi-info-circle text-primary me-2"></i>${item}</li>`;
                    });
                }
                $("#notifList").html(html);
            });
        }

        function toggleNotifications() {
            isOpen = !isOpen;
            if (isOpen) {
                $("#notifBox").show();
                loadNotificationList();
            } else {
                $("#notifBox").hide();
            }
        }

        function clearNotifications() {
            $.post('/Query/ClearNotifications', function () {
                $("#notifList").html("<li class='user-notif-empty'>No new updates</li>");
                $("#notifCount").text("0").hide();
            });
        }

        setInterval(loadNotifications, 5000); // 5 seconds is usually better for performance
        loadNotifications();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> *@




<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SolvePoint</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        #preloader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #ffffff;
            z-index: 10000;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.6s cubic-bezier(0.645, 0.045, 0.355, 1);
        }

        /* Logo Pulse Effect */
        .logo-animation {
            position: relative;
            display: inline-block;
        }

        .pulse-ring {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100px;
            height: 100px;
            border: 2px solid #4f46e5;
            border-radius: 50%;
            animation: ripple 1.5s infinite;
        }

        @@keyframes ripple {
            0% {
                width: 50px;
                height: 50px;
                opacity: 1;
            }

            100% {
                width: 150px;
                height: 150px;
                opacity: 0;
            }
        }

        /* Sleek Progress Bar */
        .progress-container {
            width: 200px;
            height: 3px;
            background: #f1f5f9;
            margin: 0 auto;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-bar-fill {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #6366f1, #4f46e5);
            animation: loadingFill 2s infinite ease-in-out;
        }

        @@keyframes loadingFill {
            0% {
                width: 0%;
                margin-left: 0;
            }

            50% {
                width: 100%;
                margin-left: 0;
            }

            100% {
                width: 0%;
                margin-left: 100%;
            }
        }

        /* Fade Out Effect */
        .preloader-hidden {
            opacity: 0;
            visibility: hidden;
            transform: scale(1.1);
        }

        :root {
            --sp-primary: #2563eb;
            --sp-bg: #f8fafc;
            --nav-height: 70px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--sp-bg);
            padding-top: var(--nav-height);
        }

        /* --- NAVBAR STYLING --- */
        .navbar-custom {
            height: var(--nav-height);
            background: rgba(255, 255, 255, 0.9) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid #e2e8f0;
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        /* --- NOTIFICATION TRIGGER & BADGE --- */
        .user-notif-wrapper {
            position: relative;
        }

        .user-notif-trigger {
            position: relative;
            cursor: pointer;
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            border: 1px solid #e2e8f0;
            color: #64748b;
            transition: all 0.2s ease;
        }

        .user-notif-trigger:hover {
            background: #e2e8f0;
            color: var(--sp-primary);
        }

        .user-notif-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: 800;
            padding: 2px 6px;
            border-radius: 50px;
            border: 2px solid #fff;
            min-width: 18px;
            text-align: center;
        }

        /* --- NOTIFICATION DROPDOWN BOX --- */
        .user-notif-box {
            display: none;
            position: absolute;
            right: 0;
            top: 55px;
            width: 320px;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            border: 1px solid #e2e8f0;
            z-index: 1100;
        }

        /* Triangle Pointer */
        .user-notif-box::before {
            content: "";
            position: absolute;
            top: -8px;
            right: 12px;
            width: 16px;
            height: 16px;
            background: white;
            transform: rotate(45deg);
            border-top: 1px solid #e2e8f0;
            border-left: 1px solid #e2e8f0;
        }

        .user-notif-header {
            padding: 16px;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            border-radius: 16px 16px 0 0;
        }

        .user-notif-list {
            list-style: none;
            padding: 0;
            margin: 0;
            max-height: 300px;
            overflow-y: auto;
        }

        .user-notif-item {
            padding: 12px 16px;
            font-size: 13px;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .user-notif-empty {
            padding: 30px 16px;
            text-align: center;
            color: #94a3b8;
            font-size: 13px;
        }

        .user-notif-footer {
            padding: 12px;
            border-top: 1px solid #f1f5f9;
        }

        .user-notif-btn {
            width: 100%;
            padding: 8px;
            border: 1px solid #e2e8f0;
            background: #fff;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            color: #475569;
            cursor: pointer;
        }

        .user-notif-btn:hover {
            background: #f8fafc;
            color: var(--sp-primary);
        }

        .sp-footer {
            background: #f8fafc;
            border-top: 1px solid #e2e8f0;
            padding: 60px 0 30px;
            margin-top: 100px;
        }

        .footer-logo {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--sp-primary);
            margin-bottom: 1rem;
            display: block;
            text-decoration: none;
        }

        .footer-link {
            text-decoration: none;
            color: #64748b;
            font-size: 0.9rem;
            transition: 0.2s;
            display: block;
            margin-bottom: 0.5rem;
        }

        .footer-link:hover {
            color: var(--sp-primary);
        }

        .social-icons i {
            font-size: 1.2rem;
            color: #94a3b8;
            margin-right: 15px;
            cursor: pointer;
            transition: 0.2s;
        }

        .social-icons i:hover {
            color: var(--sp-primary);
        }
    </style>
</head>

<body>

    <div id="preloader">
        <div class="loader-wrapper text-center">
            <div class="logo-animation mb-4">
                <span class="display-4 fw-bold text-primary">S</span>
                <span class="display-4 fw-bold text-dark">P</span>
                <div class="pulse-ring"></div>
            </div>

            <div class="progress-container">
                <div class="progress-bar-fill"></div>
            </div>

            <h5 class="mt-4 fw-light tracking-widest text-uppercase" style="letter-spacing: 4px;">SolvePoint</h5>
            <div class="text-muted small mt-2">Optimizing your experience...</div>
        </div>
