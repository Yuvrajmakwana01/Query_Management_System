            max-height: 250px;
            overflow: auto;
            background: #fcfdff;
        }

        .user-notif-item {
            padding: 12px 14px;
            margin-bottom: 10px;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            background: linear-gradient(135deg, #ffffff, #f8fbff);
            color: #1e293b;
            font-size: 14px;
            line-height: 1.45;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
        }

        .user-notif-item:last-child {
            margin-bottom: 0;
        }

        .user-notif-empty {
            padding: 28px 16px;
            text-align: center;
            color: #64748b;
            font-size: 14px;
        }

        .user-notif-footer {
            padding: 14px 16px 16px;
            border-top: 1px solid #eef2f7;
            background: #fff;
