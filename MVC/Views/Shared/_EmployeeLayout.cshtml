<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Employee SolvePoint</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        #preloader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #ffffff;
            z-index: 10000;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.6s cubic-bezier(0.645, 0.045, 0.355, 1);
        }

        /* Logo Pulse Effect */
        .logo-animation {
            position: relative;
            display: inline-block;
        }

        .pulse-ring {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100px;
            height: 100px;
            border: 2px solid #4f46e5;
            border-radius: 50%;
            animation: ripple 1.5s infinite;
        }

        @@keyframes ripple {
            0% {
                width: 50px;
                height: 50px;
                opacity: 1;
            }

            100% {
                width: 150px;
                height: 150px;
                opacity: 0;
            }
        }

        /* Sleek Progress Bar */
        .progress-container {
            width: 200px;
            height: 3px;
            background: #f1f5f9;
            margin: 0 auto;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-bar-fill {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #6366f1, #4f46e5);
            animation: loadingFill 2s infinite ease-in-out;
        }

        @@keyframes loadingFill {
            0% {
                width: 0%;
                margin-left: 0;
            }

            50% {
                width: 100%;
                margin-left: 0;
            }

            100% {
                width: 0%;
                margin-left: 100%;
            }
        }

        /* Fade Out Effect */
        .preloader-hidden {
            opacity: 0;
            visibility: hidden;
            transform: scale(1.1);
        }

        :root {
            --sp-primary: #2563eb;
            --sp-bg: #f8fafc;
            --nav-height: 70px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--sp-bg);
            padding-top: var(--nav-height);
        }

        /* --- PREMIUM NAVBAR --- */
        .navbar-custom {
            height: var(--nav-height);
            background: rgba(255, 255, 255, 0.9) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid #e2e8f0;
            z-index: 1030;
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .nav-link {
            font-weight: 600;
            color: #475569 !important;
            transition: all 0.2s;
        }

        .nav-link:hover {
            color: var(--sp-primary) !important;
        }

        /* --- NOTIFICATION SYSTEM --- */
        .user-notif-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .user-notif-trigger {
            position: relative;
            cursor: pointer;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            border: 1px solid #e2e8f0;
            color: #64748b;
        }

        .user-notif-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: 800;
            padding: 2px 6px;
            border-radius: 50px;
            border: 2px solid #fff;
        }

        .user-notif-box {
            display: none;
            position: absolute;
            right: 0;
            top: 55px;
            width: 320px;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            border: 1px solid #e2e8f0;
            z-index: 1100;
        }

        .user-notif-box::before {
            content: "";
            position: absolute;
            top: -8px;
            right: 12px;
            width: 16px;
            height: 16px;
            background: white;
            transform: rotate(45deg);
            border-top: 1px solid #e2e8f0;
            border-left: 1px solid #e2e8f0;
        }

        .user-notif-header {
            padding: 15px;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            border-radius: 16px 16px 0 0;
        }

        .user-notif-list {
            list-style: none;
            padding: 0;
            margin: 0;
            max-height: 280px;
            overflow-y: auto;
        }

        .user-notif-item {
            padding: 12px 15px;
            font-size: 13px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            gap: 10px;
        }

        .footer-custom {
            padding: 20px 0;
            background: #fff;
            border-top: 1px solid #e2e8f0;
            margin-top: 50px;
        }
    </style>
</head>

<body>

    <div id="preloader">
        <div class="loader-wrapper text-center">
            <div class="logo-animation mb-4">
                <span class="display-4 fw-bold text-primary">S</span>
                <span class="display-4 fw-bold text-dark">P</span>
                <div class="pulse-ring"></div>
            </div>

            <div class="progress-container">
                <div class="progress-bar-fill"></div>
            </div>

            <h5 class="mt-4 fw-light tracking-widest text-uppercase" style="letter-spacing: 4px;">SolvePoint</h5>
            <div class="text-muted small mt-2">Optimizing your experience...</div>
        </div>
    </div>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light fixed-top navbar-custom">
            <div class="container">
                @* <a class="navbar-brand fw-bold text-black" asp-area="" asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-intersect text-primary me-2"></i> Solve<span class="text-primary">Point</span>.
                </a> *@

                <a class="navbar-brand" asp-controller="Employee" asp-action="Dashboard">
                    <img src="~/images/SolvePoint.png" width="160"
                        style="mix-blend-mode: multiply; border-radius: 12px;" />
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navContent">
                    <ul class="navbar-nav mx-auto mb-2 mb-sm-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Employee"
                                asp-action="Dashboard">Dashboard</a>
                        </li>

                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <div class="user-notif-wrapper">
                            <div class="user-notif-trigger" onclick="toggleNotifications(event)">
                                <i class="bi bi-bell-fill" style="font-size: 1.2rem;"></i>
                                <span id="notifCount" class="user-notif-count" style="display:none;">0</span>
                            </div>

                            <div id="notifBox" class="user-notif-box">
                                <div class="user-notif-header">
                                    <p class="fw-bold mb-0" style="font-size: 14px;">Notifications</p>
                                    <p class="text-muted mb-0" style="font-size: 12px;">New queries assigned to you.</p>
                                </div>
                                <ul id="notifList" class="user-notif-list"></ul>
                                <div class="p-2 border-top">
                                    <button onclick="clearNotifications()" class="btn btn-light btn-sm w-100 fw-bold"
                                        style="font-size: 11px;">
                                        Mark all as read
                                    </button>
                                </div>
                            </div>
                        </div>

                        <a class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold" asp-area=""
                            asp-controller="Employee" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="py-3 my-4 border-top">
        <div class="container d-flex flex-wrap justify-content-between align-items-center">

            <div class="col-md-4 d-flex align-items-center">
                <span class="mb-3 mb-md-0 text-muted small">
                    © 2026 <strong>SolvePoint</strong> — Employee Portal
                </span>
            </div>

            <div class="col-md-4 d-flex justify-content-center">
                <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                    <i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>
                    System Live
                </span>
            </div>

            <ul class="nav col-md-4 justify-content-end list-unstyled d-flex">
                <li class="ms-3">
                    <a class="text-muted small text-decoration-none" href="/Home/Privacy">Help Center</a>
                </li>
                <li class="ms-3 border-start ps-3">
                    <span class="text-muted small">v2.1.0</span>
                </li>
            </ul>

        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>

    <script>

        document.addEventListener("DOMContentLoaded", function () {
            const preloader = document.getElementById('preloader');

            window.addEventListener('load', function () {
                // Give it a tiny extra moment for Kendo UI to settle
                setTimeout(() => {
                    preloader.classList.add('preloader-hidden');
                }, 800);
            });
        });

        function toggleNotifications(event) {
            event.stopPropagation();
            $("#notifBox").fadeToggle(150);
            if ($("#notifBox").is(":visible")) loadNotificationList();
        }

        $(document).click(function (e) {
            if (!$(e.target).closest('.user-notif-wrapper').length) {
                $("#notifBox").fadeOut(100);
            }
        });

        function loadNotifications() {
            // Updated to Employee controller path
            $.get('/Employee/GetNotificationCount', function (data) {
                let count = parseInt(data) || 0;
                count > 0 ? $("#notifCount").text(count).show() : $("#notifCount").hide();
            });
        }

        function loadNotificationList() {
            $.get('/Employee/GetNotifications', function (data) {
                let html = (data && data.length > 0)
                    ? data.reverse().map(item => `<li class="user-notif-item"><i class="bi bi-info-circle text-primary"></i><span>${item}</span></li>`).join('')
                    : "<li class='p-4 text-center text-muted' style='font-size:12px;'>No assignments</li>";
                $("#notifList").html(html);
            });
        }

        function clearNotifications() {
            $.post('/Employee/ClearNotifications', function () {
                $("#notifList").html("<li class='p-4 text-center text-muted' style='font-size:12px;'>No assignments</li>");
                $("#notifCount").hide();
            });
        }

        setInterval(loadNotifications, 10000);
        loadNotifications();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>