<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SolvePoint</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <style>
        #preloader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #ffffff;
            z-index: 10000;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.6s cubic-bezier(0.645, 0.045, 0.355, 1);
        }

        /* Logo Pulse Effect */
        .logo-animation {
            position: relative;
            display: inline-block;
        }

        .pulse-ring {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100px;
            height: 100px;
            border: 2px solid #4f46e5;
            border-radius: 50%;
            animation: ripple 1.5s infinite;
        }

        @@keyframes ripple {
            0% {
                width: 50px;
                height: 50px;
                opacity: 1;
            }

            100% {
                width: 150px;
                height: 150px;
                opacity: 0;
            }
        }

        /* Sleek Progress Bar */
        .progress-container {
            width: 200px;
            height: 3px;
            background: #f1f5f9;
            margin: 0 auto;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-bar-fill {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #6366f1, #4f46e5);
            animation: loadingFill 2s infinite ease-in-out;
        }

        @@keyframes loadingFill {
            0% {
                width: 0%;
                margin-left: 0;
            }

            50% {
                width: 100%;
                margin-left: 0;
            }

            100% {
                width: 0%;
                margin-left: 100%;
            }
        }

        /* Fade Out Effect */
        .preloader-hidden {
            opacity: 0;
            visibility: hidden;
            transform: scale(1.1);
        }

        :root {
            --sp-primary: #4f46e5;
            --sp-secondary: #0ea5e9;
            --navbar-height: 72px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            padding-top: var(--navbar-height);
            /* Prevent content jump */
        }

        /* --- MODERN NAVBAR --- */
        .main-nav {
            height: var(--navbar-height);
            background: rgba(255, 255, 255, 0.8) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05) !important;
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            font-size: 1.4rem;
        }

        .nav-link {
            font-weight: 600;
            font-size: 0.95rem;
            color: #475569 !important;
            margin: 0 10px;
            transition: color 0.2s ease;
        }

        .nav-link:hover {
            color: var(--sp-primary) !important;
        }

        /* Specialized Action Buttons */
        .btn-login {
            color: var(--sp-primary) !important;
            border: 1.5px solid var(--sp-primary);
            border-radius: 10px;
            padding: 8px 20px !important;
        }

        .btn-register {
            background: var(--sp-primary);
            color: white !important;
            border-radius: 10px;
            padding: 8px 22px !important;
            margin-left: 10px;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        }



        /* --- PROFESSIONAL FOOTER --- */
        .sp-footer {
            background: #f8fafc;
            border-top: 1px solid #e2e8f0;
            padding: 60px 0 30px;
            margin-top: 100px;
        }

        .footer-logo {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--sp-primary);
            margin-bottom: 1rem;
            display: block;
            text-decoration: none;
        }

        .footer-link {
            text-decoration: none;
            color: #64748b;
            font-size: 0.9rem;
            transition: 0.2s;
            display: block;
            margin-bottom: 0.5rem;
        }

        .footer-link:hover {
            color: var(--sp-primary);
        }

        .social-icons i {
            font-size: 1.2rem;
            color: #94a3b8;
            margin-right: 15px;
            cursor: pointer;
            transition: 0.2s;
        }

        .social-icons i:hover {
            color: var(--sp-primary);
        }
    </style>
</head>

<body>


    <div id="preloader">
    <div class="loader-wrapper text-center">
        <div class="logo-animation mb-4">
            <span class="display-4 fw-bold text-primary">S</span>
            <span class="display-4 fw-bold text-dark">P</span>
            <div class="pulse-ring"></div>
        </div>

        <div class="progress-container">
            <div class="progress-bar-fill"></div>
        </div>

        <h5 class="mt-4 fw-light tracking-widest text-uppercase" style="letter-spacing: 4px;">SolvePoint</h5>
        <div class="text-muted small mt-2">Optimizing your experience...</div>
    </div>
</div>


    <header>
        <nav class="navbar navbar-expand-md navbar-light fixed-top main-nav">
            <div class="container">
                @* <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-intersect text-primary me-2"></i> Solve <span class="text-primary">Point</span>.
                </a> *@
                 <a class="navbar-brand" asp-controller="Account" asp-action="Login">
                    <img src="~/images/SolvePoint.png" width="160"  style="mix-blend-mode: multiply; border-radius: 12px;"/>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About1">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Help</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center">
                        <a class="nav-link btn-login" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="nav-link btn-register" asp-controller="User" asp-action="Register">Register</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="sp-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-12">
                    <a class="footer-logo" href="#">Solve<span class="text-black">Point</span>.</a>
                    <p class="text-muted small w-75">Transforming support workflows with intelligent query management
                        and real-time tracking.</p>
                    <div class="social-icons">
                        <i class="bi bi-github"></i>
                        <i class="bi bi-linkedin"></i>
                        <i class="bi bi-twitter-x"></i>
                    </div>
                </div>
                <div class="col-lg-2 col-6">
                    <h6 class="fw-bold mb-3">Product</h6>
                    <a class="footer-link" href="#">Features</a>
                    <a class="footer-link" href="#">Pricing</a>
                    <a class="footer-link" href="#">Changelog</a>
                </div>
                <div class="col-lg-2 col-6">
                    <h6 class="fw-bold mb-3">Company</h6>
                    <a class="footer-link" asp-controller="Home" asp-action="About1">About Us</a>
                    <a class="footer-link" href="#">Careers</a>
                    <a class="footer-link" href="#">Contact</a>
                </div>
                <div class="col-lg-4 col-md-12">
                    <h6 class="fw-bold mb-3">Stay Updated</h6>
                    <div class="input-group mb-3">
                        <input type="text" class="form-control border-end-0" placeholder="Email address">
                        <button class="btn btn-dark" type="button">Connect Now</button>
                    </div>
                </div>
            </div>
            <hr class="my-4 opacity-50">
            <div class="row">
                <div class="col-md-6 text-center text-md-start">
                    <small class="text-muted">&copy; 2026 SolvePoint QMS. Built for efficiency.</small>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="footer-link d-inline-block me-3">Privacy Policy</a>
                    <a href="#" class="footer-link d-inline-block">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const preloader = document.getElementById('preloader');

            window.addEventListener('load', function () {
                // Give it a tiny extra moment for Kendo UI to settle
                setTimeout(() => {
                    preloader.classList.add('preloader-hidden');
                }, 800);
            });
        });
    </script>
</body>

</html>